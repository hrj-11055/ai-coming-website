# AI News Management System - Environment Variables
# Copy this file to .env and update with your values

# =====================================================
# Server Configuration 服务器配置
# =====================================================
PORT=3000
STATIC_ROOT=.
NODE_ENV=development

# =====================================================
# JWT Configuration JWT配置
# =====================================================
# JWT Secret (REQUIRED - Change this to a secure random string)
JWT_SECRET=ai-coming-secret-key-please-change-in-production

# =====================================================
# MySQL Database Configuration 数据库配置
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=ai_news_system
DB_CONNECTION_LIMIT=10

# =====================================================
# Default Admin Account 默认管理员
# =====================================================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
DEFAULT_ADMIN_ROLE=super_admin

# =====================================================
# Security Configuration 安全配置
# =====================================================
# bcrypt Salt Rounds (Higher is more secure but slower)
BCRYPT_SALT_ROUNDS=10

# =====================================================
# SiliconFlow API Configuration 硅基流动API配置
# =====================================================
# 获取方式：访问 https://siliconflow.cn → 控制台 → API密钥
# REQUIRED - 配置您的硅基流动API密钥
SILICONFLOW_API_KEY=sk-your_api_key_here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# =====================================================
# Alibaba Cloud Qwen API Configuration 阿里云千问API配置
# =====================================================
# 获取方式：访问 https://bailian.console.aliyun.com/ → API-KEY管理
# 用于模型对比测试（可选）
# 获取API Key: https://bailian.console.aliyun.com/?tab=api#/api/
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen3.5-plus
# 兼容别名（后端也支持该变量名）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen3.5-plus

# 官网首页大模型用量统计
# 按当前固定模型在供应商后台配置输入/输出 token 单价；单位：每 100 万 tokens。
AI_INPUT_PRICE_PER_MILLION_TOKENS=0.8
AI_OUTPUT_PRICE_PER_MILLION_TOKENS=4.8
AI_USAGE_CURRENCY=CNY
AI_USAGE_TIMEZONE=Asia/Shanghai
AI_USAGE_IP_HASH_SALT=replace-with-a-stable-random-string

# =====================================================
# DeepSeek API Configuration DeepSeek配置
# =====================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# =====================================================
# 图片生成 API (gpt-image-2 中转站)
# =====================================================
GPT_IMAGE_API_KEY=sk-your-key-here
GPT_IMAGE_API_BASE_URL=https://www.bytecatcode.org

# =====================================================
# Podcast TTS Configuration 播客语音生成配置
# =====================================================
# 播客脚本生成默认继承 DeepSeek V4 Flash；如需单独覆盖，再填写 PODCAST_SCRIPT_*。
PODCAST_SCRIPT_API_KEY=your_podcast_script_api_key_here
PODCAST_SCRIPT_API_URL=https://api.deepseek.com/chat/completions
PODCAST_SCRIPT_MODEL=deepseek-v4-flash
PODCAST_SCRIPT_INPUT_DIR=/var/www/json/report
PODCAST_SCRIPT_TIMEOUT_MS=120000
PODCAST_SCRIPT_MAX_TOKENS=2200
PODCAST_SCRIPT_MAX_RETRIES=3
PODCAST_SCRIPT_RETRY_BASE_DELAY_MS=1000
PODCAST_SCRIPT_SYSTEM_PROMPT_FILE=./config/podcast-script-system-prompt.md

# MiniMax TTS（异步语音合成，默认系统音色）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_TTS_API_URL=https://api.minimaxi.com/v1/t2a_async_v2
MINIMAX_TTS_QUERY_API_URL=https://api.minimaxi.com/v1/query/t2a_async_query_v2
MINIMAX_TTS_FILE_METADATA_API_URL=https://api.minimaxi.com/v1/files/retrieve
MINIMAX_TTS_FILE_API_URL=https://api.minimaxi.com/v1/files/retrieve_content
MINIMAX_TTS_MODEL=speech-2.8-turbo
# 必填：填写 MiniMax 官方默认音色 voice_id
MINIMAX_TTS_VOICE_ID=male-qn-jingying
MINIMAX_TTS_SPEED=1.0
MINIMAX_TTS_VOLUME=1.0
MINIMAX_TTS_PITCH=0
MINIMAX_TTS_FORMAT=mp3
MINIMAX_TTS_LANGUAGE_BOOST=Chinese
MINIMAX_TTS_POLL_INTERVAL_MS=3000
MINIMAX_TTS_TIMEOUT_MS=600000

# 播客 ready 后自动发送邮件（当前正式下游链路）
PODCAST_EMAIL_ENABLED=true
PODCAST_EMAIL_TO=noel.huang@aicoming.cn
PODCAST_EMAIL_STATE_FILE=./data/podcast-email-state.json
PODCAST_EMAIL_TIMEZONE=Asia/Shanghai
PODCAST_EMAIL_SITE_BASE_URL=https://ai-coming.com

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=bot@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=AIcoming <bot@example.com>

# 历史兼容：旧的播客补偿扫描脚本保留，但不再是正式下游链路
PODCAST_AUTOGEN_ENABLED=false
PODCAST_AUTOGEN_API_BASE_URL=http://127.0.0.1:3000
PODCAST_AUTOGEN_TIMEZONE=Asia/Shanghai
PODCAST_AUTOGEN_START_HOUR=9
PODCAST_AUTOGEN_START_MINUTE=5
PODCAST_AUTOGEN_TRIGGER_TIMEOUT_MS=15000
PODCAST_AUTOGEN_STATE_FILE=./data/podcast-autogen-state.json

# 历史兼容：微信公众号自动任务保留，但不再是正式下游链路
# 必填：微信公众号后台 -> 开发 -> 基本配置
WECHAT_APP_ID=wx-your_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_AUTOGEN_ENABLED=false
WECHAT_AUTOGEN_TIMEZONE=Asia/Shanghai
WECHAT_AUTOGEN_START_HOUR=9
WECHAT_AUTOGEN_START_MINUTE=5
WECHAT_AUTOGEN_STATE_FILE=./data/wechat-autogen-state.json
WECHAT_AUTOGEN_REPORT_DIR=/var/www/json/report
WECHAT_AUTOGEN_PODCAST_METADATA_DIR=./data/podcasts/news
WECHAT_AUTOGEN_STAGING_DIR=./data/wechat-staging
WECHAT_AUTOGEN_DEFAULT_AUTHOR=AIcoming
# 必填：服务器上的封面图绝对路径
WECHAT_AUTOGEN_DEFAULT_COVER_IMAGE=/var/www/ai-coming-website/pic/wechat-cover.jpg
# 必填：用于拼接播客收听链接的公网地址
WECHAT_AUTOGEN_SITE_BASE_URL=https://ai-coming.com
# 可选：podcast,markdown
WECHAT_AUTOGEN_ENABLED_TYPES=podcast,markdown
# 音频消息发送：sendall 或 preview
WECHAT_AUTOGEN_AUDIO_SEND_MODE=sendall
# 群发到全部粉丝；若设为 false，则必须配置 WECHAT_AUTOGEN_AUDIO_TAG_ID
WECHAT_AUTOGEN_AUDIO_SEND_TO_ALL=true
WECHAT_AUTOGEN_AUDIO_TAG_ID=
# preview 模式时使用，二选一
WECHAT_AUTOGEN_AUDIO_PREVIEW_OPENID=
WECHAT_AUTOGEN_AUDIO_PREVIEW_WXNAME=

# Alibaba Cloud OSS for podcast audio（可选）
# 如果不填写 OSS，系统会把日报播客音频保存在本地 data/podcasts/news/audio 并通过 /api/podcast/news/:date/audio 播放
PODCAST_OSS_REGION=oss-cn-shenzhen
PODCAST_OSS_BUCKET=my-podcast-2026
PODCAST_OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
PODCAST_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
# 可选：留空时默认使用 https://<bucket>.<region>.aliyuncs.com
PODCAST_OSS_PUBLIC_BASE_URL=https://my-podcast-2026.oss-cn-shenzhen.aliyuncs.com
