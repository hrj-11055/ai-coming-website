# AI News Management System - Environment Variables
# Copy this file to .env and update with your values

# =====================================================
# Server Configuration 服务器配置
# =====================================================
PORT=3000
STATIC_ROOT=.
NODE_ENV=development

# =====================================================
# JWT Configuration JWT配置
# =====================================================
# JWT Secret (REQUIRED - Change this to a secure random string)
JWT_SECRET=ai-coming-secret-key-please-change-in-production

# =====================================================
# MySQL Database Configuration 数据库配置
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=ai_news_system
DB_CONNECTION_LIMIT=10

# =====================================================
# Default Admin Account 默认管理员
# =====================================================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
DEFAULT_ADMIN_ROLE=super_admin

# =====================================================
# Security Configuration 安全配置
# =====================================================
# bcrypt Salt Rounds (Higher is more secure but slower)
BCRYPT_SALT_ROUNDS=10

# =====================================================
# SiliconFlow API Configuration 硅基流动API配置
# =====================================================
# 获取方式：访问 https://siliconflow.cn → 控制台 → API密钥
# REQUIRED - 配置您的硅基流动API密钥
SILICONFLOW_API_KEY=sk-your_api_key_here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# =====================================================
# Alibaba Cloud Qwen API Configuration 阿里云千问API配置
# =====================================================
# 获取方式：访问 https://bailian.console.aliyun.com/ → API-KEY管理
# 用于模型对比测试（可选）
# 获取API Key: https://bailian.console.aliyun.com/?tab=api#/api/
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen3.5-plus
# 兼容别名（后端也支持该变量名）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen3.5-plus

# =====================================================
# Podcast TTS Configuration 播客语音生成配置
# =====================================================
# YunTTS IndexTTS2 API
YUNTTS_API_URL=https://www.yuntts.com/api/v1/indextts2_generate
YUNTTS_CLONE_API_URL=https://www.yuntts.com/api/v1/indextts2_cloning
YUNTTS_QUERY_API_URL=https://www.yuntts.com/api/v1/indextts_query
YUNTTS_API_KEY=your_yuntts_app_key_here
# 可选：如果你已经有固定 voice_id，可以直接填写
YUNTTS_VOICE=
YUNTTS_SPEAKER_ID=jack_cheng
# 可选：配置样本音频后，系统会优先自动克隆该音色用于播客生成
YUNTTS_CLONE_SAMPLE_FILE=
YUNTTS_CLONE_NAME=AIcoming Podcast Voice
YUNTTS_CLONE_DESCRIPTION=AIcoming daily podcast voice clone
YUNTTS_RESPONSE_FORMAT=mp3
YUNTTS_SAMPLE_RATE=24000
YUNTTS_SPEED=1.0
YUNTTS_INTERVAL_SILENCE=100
YUNTTS_SEED=42

# Alibaba Cloud OSS for podcast audio（可选）
# 如果不填写 OSS，系统会把日报播客音频保存在本地 data/podcasts/news/audio 并通过 /api/podcast/news/:date/audio 播放
PODCAST_OSS_REGION=oss-cn-shenzhen
PODCAST_OSS_BUCKET=my-podcast-2026
PODCAST_OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
PODCAST_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
# 可选：留空时默认使用 https://<bucket>.<region>.aliyuncs.com
PODCAST_OSS_PUBLIC_BASE_URL=https://my-podcast-2026.oss-cn-shenzhen.aliyuncs.com
